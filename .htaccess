# ═══════════════════════════════════════════
#  Life Charge Chiropractic — Apache config
#  Performance + SEO + 301 redirects + security
#  Replaces previous WordPress / LiteSpeed .htaccess
# ═══════════════════════════════════════════

Options -MultiViews -Indexes
DirectoryIndex index.html index.php
ErrorDocument 404 /404.html

RewriteEngine On
RewriteBase /

# ─── Force HTTPS ───
RewriteCond %{HTTPS} off
RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# ─── Force non-www (canonicalize domain for SEO) ───
RewriteCond %{HTTP_HOST} ^www\.lifechargechiropractic\.com$ [NC]
RewriteRule ^ https://lifechargechiropractic.com%{REQUEST_URI} [L,R=301]

# ─────────────────────────────────────────────
# STEP 1 — explicit 301 redirects from old WordPress URLs
# Run before any rewrites so they take precedence.
# ─────────────────────────────────────────────

# Typo
RewriteRule ^our-philosphy/?$ /our-philosophy/ [R=301,L]

# Old slug variants
RewriteRule ^reviews-2/?$        /reviews/        [R=301,L]
RewriteRule ^caraccident/?$      /auto-accident/  [R=301,L]
RewriteRule ^elementor-821/?$    /                [R=301,L]

# Pages without a direct equivalent — redirect to closest topical match
RewriteRule ^kneepain/?$        /sports-injury/            [R=301,L]
RewriteRule ^shoulder-pain/?$   /sports-injury/            [R=301,L]
RewriteRule ^headaches/?$       /headaches-and-migraines/  [R=301,L]
RewriteRule ^headachequiz/?$    /headaches-and-migraines/  [R=301,L]
RewriteRule ^lowbackpainquiz/?$ /low-back-pain/            [R=301,L]
RewriteRule ^painquiz/?$        /contact-us/               [R=301,L]
RewriteRule ^claimoffer/?$      /contact-us/               [R=301,L]
RewriteRule ^chat/?$            /contact-us/               [R=301,L]
RewriteRule ^refer/?$           /contact-us/               [R=301,L]
RewriteRule ^referral-list/?$   /contact-us/               [R=301,L]
RewriteRule ^digest/?$          /blog/                     [R=301,L]
RewriteRule ^spine-atlas/?$         / [R=301,L]
RewriteRule ^movement-tracker/?$    / [R=301,L]
RewriteRule ^spineai-evaluation/?$  / [R=301,L]
RewriteRule ^llms-txt/?$            / [R=301,L]
RewriteRule ^conditions-we-help-gallatin-chiropractor/?$ /low-back-pain/ [R=301,L]
RewriteRule ^thermal-imaging-services-at-life-charge-chiropractic/?$ /thermal-imaging/ [R=301,L]
RewriteRule ^eat-strong-stay-strong-the-diet-that-supports-longevity-after-55/?$ /blog/ [R=301,L]

# Specific 404 blog URLs flagged by SEMrush — redirect to closest topical page
RewriteRule ^blog/2025/05/03/why-chiropractic-care-is-essential-after-a-car-accident-in-gallatin-and-hendersonville/?$ /auto-accident/   [R=301,L]
RewriteRule ^blog/2025/05/31/a-chiropractors-guide-to-your-babys-growing-spine-0-2-years/?$                          /pediatric/       [R=301,L]
RewriteRule ^blog/2026/04/22/thermography-vs-x-ray-what-each-one-actually-shows-you/?$                               /thermal-imaging/ [R=301,L]

# All old WordPress dated blog posts → same post under /blog/
RewriteRule ^([0-9]{4}/[0-9]{2}/[0-9]{2}/.+/?$) /blog/$1 [R=301,L]

# Old PKX permalink variant
RewriteRule ^find-a-pi-kappa-chi-brother/?$ /find-a-pi-kappa-chi-brother-2/ [R=301,L]

# Preserve old absolute media URLs from WordPress posts.
RewriteRule ^wp-content/uploads/(.*)$ /blog/wp-content/uploads/$1 [R=301,L]

# Block legacy WordPress endpoints at the site root.
RewriteRule ^wp-admin(/.*)?$  /  [R=301,L]
RewriteRule ^wp-login\.php$    /  [R=301,L]
RewriteRule ^wp-content(/.*)?$ /  [R=301,L]
RewriteRule ^xmlrpc\.php$      -  [F,L]

# ─────────────────────────────────────────────
# STEP 2 — strip .html so /about.html → /about/
# Triggers only on direct user requests (THE_REQUEST), not internal rewrites.
# ─────────────────────────────────────────────
RewriteCond %{THE_REQUEST} \s/+([^\s]+?)\.html[\s?] [NC]
RewriteRule ^ /%1/ [R=301,L]

# Strip /index for the homepage
RewriteCond %{THE_REQUEST} \s/+index/?[\s?] [NC]
RewriteRule ^ / [R=301,L]

# ─────────────────────────────────────────────
# STEP 3 — internally serve /about/ (or /about) from /about.html
# Skip if it's already a real file or directory.
# ─────────────────────────────────────────────
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^([^/.]+)/?$ /$1.html [L]

# ─── Block sensitive files ───
<FilesMatch "^\.">
  Require all denied
</FilesMatch>
<FilesMatch "\.(md|log|bak|inc|sql|env)$">
  Require all denied
</FilesMatch>
<FilesMatch "(wp-config\.php|wp-cron\.php|wp-blog-header\.php|xmlrpc\.php|wp-mail\.php|wp-trackback\.php|wp-comments-post\.php|wp-load\.php|wp-settings\.php|wp-activate\.php|wp-signup\.php|wp-links-opml\.php)$">
  Require all denied
</FilesMatch>

# ─── Compression ───
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css text/javascript
  AddOutputFilterByType DEFLATE application/javascript application/x-javascript
  AddOutputFilterByType DEFLATE application/json application/xml application/rss+xml application/atom+xml
  AddOutputFilterByType DEFLATE image/svg+xml font/ttf font/otf
</IfModule>

# ─── Browser caching ───
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresDefault                          "access plus 1 month"
  ExpiresByType text/html                 "access plus 1 hour"
  ExpiresByType text/css                  "access plus 1 year"
  ExpiresByType application/javascript    "access plus 1 year"
  ExpiresByType text/javascript           "access plus 1 year"
  ExpiresByType image/webp                "access plus 1 year"
  ExpiresByType image/jpeg                "access plus 1 year"
  ExpiresByType image/png                 "access plus 1 year"
  ExpiresByType image/svg+xml             "access plus 1 year"
  ExpiresByType image/x-icon              "access plus 1 year"
  ExpiresByType font/ttf                  "access plus 1 year"
  ExpiresByType font/woff                 "access plus 1 year"
  ExpiresByType font/woff2                "access plus 1 year"
  ExpiresByType application/font-woff2    "access plus 1 year"
  ExpiresByType application/xml           "access plus 1 day"
  ExpiresByType text/xml                  "access plus 1 day"
</IfModule>

# ─── Cache-Control + security headers ───
<IfModule mod_headers.c>
  <FilesMatch "\.(css|js|webp|jpg|jpeg|png|gif|svg|ico|ttf|woff|woff2)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
  <FilesMatch "\.(html|htm|xml|txt)$">
    Header set Cache-Control "public, max-age=3600, must-revalidate"
  </FilesMatch>

  Header set X-Content-Type-Options "nosniff"
  Header set X-Frame-Options "SAMEORIGIN"
  Header set Referrer-Policy "strict-origin-when-cross-origin"
  Header set Permissions-Policy "geolocation=(), microphone=(), camera=()"
  # Header set Strict-Transport-Security "max-age=31536000; includeSubDomains" env=HTTPS
</IfModule>

# ─── MIME types ───
<IfModule mod_mime.c>
  AddType image/webp .webp
  AddType image/svg+xml .svg
  AddType font/woff2 .woff2
  AddType font/ttf .ttf
  AddType application/manifest+json .webmanifest
</IfModule>
